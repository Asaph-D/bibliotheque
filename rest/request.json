# Base URL REST (module rest)
http://localhost:8081

# [1] OVER-FETCHING (REST)
# REST renvoie un format fixe => beaucoup de champs (over-fetching)
# OVER-FETCHING
GET http://localhost:8081/api/livres

# [2] UNDER-FETCHING (REST)
# Pour reproduire "livres + auteur + empruntsActifs", il faut plusieurs appels HTTP
# (dans le dashboard: appel agrégé = /api/livres + N appels /api/emprunts?livreId=...&actifs=true)
# UNDER-FETCHING
GET http://localhost:8081/api/livres

# [3] MUTATION (REST) — emprunter un livre
# MUTATION
POST http://localhost:8081/api/livres/5/emprunter?adherentId=2

# [4] SUBSCRIPTION (REST)
# Pas d'équivalent REST direct (il faudrait polling / SSE / WebSocket)
# SUBSCRIPTION
GET http://localhost:8081/api/livres